# ── Google AI ─────────────────────────────────────────────────────
# Get your free API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# ── Discord ───────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_REPORT_CHANNEL_ID=
DISCORD_AI_CHANNEL_ID=      # channel where anyone can chat freely with the bot (no @mention needed)

# ── Database ──────────────────────────────────────────────────────
DB_PATH=./data/tickets.db

# ── Daily Report ──────────────────────────────────────────────────
REPORT_CRON=0 8 * * *
REPORT_TIMEZONE=Asia/Dubai

# ── Conversation ──────────────────────────────────────────────────
MAX_HISTORY_TURNS=20

# ── Company ───────────────────────────────────────────────────────
COMPANY_NAME=My Team

# ── App ───────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
